# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/franchise-ready?retryWrites=true&w=majority
MONGODB_DB=franchise-ready

# Meta / WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
META_VERIFY_TOKEN=franchise_ready_webhook_2024
META_APP_SECRET=

# NestJS backend — full base URL, no trailing slash
# freddy_bot appends /api/v1/... to this value
BACKEND_URL=http://localhost:3001

# Must match backend INTERNAL_WEBHOOK_SECRET
INTERNAL_WEBHOOK_SECRET=

# Port for gunicorn / flask (PM2 overrides this to 5001)
PORT=5001
