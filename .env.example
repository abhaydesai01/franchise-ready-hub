# Nest backend (see backend/.env PORT; default 3001). No trailing slash.
# Development: this repo also ships `.env.development` with the same value so `npm run dev` works without copying files.
VITE_API_URL=http://localhost:3001/api/v1

# Production: set to your deployed API, e.g. https://api.franchise-ready.in/api/v1
# The admin UI (this Vite app) calls the Nest API; OAuth redirects use FRONTEND_URL / CRM_PUBLIC_URL on the backend.
