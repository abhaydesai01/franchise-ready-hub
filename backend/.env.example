# --- MongoDB Atlas ---
# Network Access "0.0.0.0/0" only allows IPs AFTER you connect. It does NOT fix:
#   querySrv ECONNREFUSED _mongodb._tcp....
# That error = DNS SRV lookup failed on YOUR network (before Atlas is contacted).
#
# Fix A (recommended): use a STANDARD URI (mongodb://host1:27017,host2:27017,...)
#   Atlas → your cluster → Connect → Connect your application → driver Node.js
#   If you only see mongodb+srv, try "Compass" / "Shell" flow or "I need a connection string without SRV"
#   (wording varies). String must list shard hostnames + ?ssl=true&replicaSet=...&authSource=admin
#
# Fix B: fix DNS — try another Wi‑Fi, disable VPN, set DNS to 1.1.1.1, corporate firewall may block SRV.
#
# Diagnose:  npm run check:atlas-dns   (loads MONGODB_URI from .env via dotenv? Node won't load .env)
# Run:       export MONGODB_URI='mongodb+srv://...' && npm run check:atlas-dns
#
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/franchise-ready?retryWrites=true&w=majority
PORT=3001
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Scorecard (PDF + WhatsApp + email) ---
# Shared with CRM: POST /api/v1/internal/scorecard/:leadId/generate
SCORECARD_INTERNAL_SECRET=generate-a-long-random-string
PUBLIC_BASE_URL=http://localhost:3001
CALENDLY_LINK=
COMPANY_NAME=Franchise Ready
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Production: leave empty to use local uploads/; or set bucket + optional public CDN base
SCORECARD_S3_BUCKET=
SCORECARD_S3_REGION=ap-south-1
SCORECARD_S3_PUBLIC_BASE_URL=
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY for S3 (default credential chain)

# Calendly webhooks + reminders (same Redis as CRM BullMQ)
REDIS_URL=
# The Admin SPA origin (where /leads/:id, /proposals/view/:token, /settings live)
# Used to build links in emails and OAuth redirects — NOT the Next.js CRM port
CRM_PUBLIC_URL=http://localhost:5173
# Same as CRM_PUBLIC_URL (used as OAuth redirect base after calendar connect)
FRONTEND_URL=http://localhost:5173
# Comma-separated list of browser origins allowed by CORS (add EC2 IP in production)
# Example: FRONTEND_ORIGINS=http://13.235.87.115,http://13.235.87.115:3000
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8080
# Shared with CRM WhatsApp bot for internal callbacks (proposal check-in reply)
INTERNAL_WEBHOOK_SECRET=
# Webhook URL for Calendly: https://<api-host>/api/v1/webhooks/calendly

# Document generation (post-call proposal / MOM) — worker:document-generation
ANTHROPIC_API_KEY=
# Optional — default uses a current Sonnet 4 snapshot; override if your org uses a specific ID
ANTHROPIC_MODEL=

# Google Gemini — after a voice call has a summary, infers scorecard + track (optional)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyCJXiVG_hPdKs05oZ1wMNCG1iO9vslkKJo
# e.g. gemini-2.0-flash, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# VAPI.ai voice fallback (30m BullMQ job → worker:voice-fallback)
# Webhook URL: https://<api-host>/api/v1/webhooks/voice
VOICE_API_KEY=
VOICE_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Optional: reject webhooks unless body field `secret` matches
VAPI_WEBHOOK_SECRET=

# Vaani Voice Agent (https://vaanivoice.ai) — optional; also configurable in CRM Settings → Integrations
# Webhook URL: https://<api-host>/api/v1/webhooks/vaani (set the same secret in Vaani portal + here)
# curl trigger (outbound_number optional — omit to use portal default):
#   curl -sS -X POST -H "X-API-Key: $VAANI_API_KEY" -H "Content-Type: application/json" \
#     -d '{"agent_id":"<uuid>","contact_number":"+91xxxxxxxxxx","name":"Test","voice":"","metadata":{}}' \
#     https://api.vaanivoice.ai/api/trigger-call/
VAANI_API_KEY=
VAANI_AGENT_ID=
VAANI_BASE_URL=https://api.vaanivoice.ai
# Optional caller ID override; leave empty if Vaani assigns outbound in the dashboard
VAANI_OUTBOUND_NUMBER=
VAANI_WEBHOOK_SECRET=

# --- Calendar (Google Calendar + Outlook) — OAuth in CRM Settings → Calendar ---
# PUBLIC_BASE_URL = API origin only (no trailing slash). Used to build:
#   {PUBLIC_BASE_URL}/api/v1/calendar/google/callback
#   {PUBLIC_BASE_URL}/api/v1/calendar/outlook/callback
# Register those exact redirect URIs in Google Cloud + Azure App Registration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
# AES key for encrypting stored tokens (generate a long random string; do not commit real values)
CALENDAR_TOKEN_ENCRYPTION_KEY=
# After OAuth, redirect uses FRONTEND_URL or CRM_PUBLIC_URL (set above) → /settings?tab=calendar

